# ============================================================
# memecoin_scorer — environment variable reference
# ============================================================
# Run `make setup-live-env` to create .env and set HELIUS_API_KEY safely.
# .env is git-ignored and must NEVER be committed.
# ============================================================

# ---- Helius API key (REQUIRED for live ingress + clustering) ----

# Real Helius API key. Run `make setup-live-env` to set this safely.
# Used for two purposes:
#   1. Ingress poller: polls Pump.fun and Raydium AMM V4 for all SWAP events
#      (broad market discovery — no wallet list required)
#   2. Clustering backend: resolves funder-parent relationships for effective buyer
#      deduplication (required for BUY/READY signals)
# Never paste the key directly into shell history or logs.
HELIUS_API_KEY=__PASTE_YOUR_HELIUS_API_KEY_HERE__

# Set to 1 (default) to require healthy clustering before BUY/READY are emitted.
# Set to 0 only in testing/smoke environments with FUNDER_MAP_PATH.
CLUSTER_REQUIRED=1

# Lookback window for Helius funder resolution (hours).
CLUSTER_LOOKBACK_HOURS=72

# Positive-cache TTL for Helius parent lookups (minutes).
CLUSTER_CACHE_TTL_MINUTES=120

# Maximum concurrent Helius API calls for funder resolution.
CLUSTER_MAX_CONCURRENCY=8

# ---- Ingress poller (broad market discovery) ----

# Seconds between poll cycles. Default: 10.
# Lower values see events sooner but use more Helius API credits.
INGRESS_POLL_INTERVAL_SEC=10

# Comma-separated Solana program accounts to watch for SWAP events.
# Leave blank to use defaults: Pump.fun bonding curve + Raydium AMM V4.
# Override to add or replace programs.
INGRESS_PROGRAMS=

# ---- Ingestor (cmd/ingestor) ----

# Port the ingestor HTTP server binds to. Default: 8080.
PORT=8080

# Helius webhook secret. When set, every POST /webhook must include
#   Authorization: Bearer <value>
# Leave blank during local testing without a tunnel.
HELIUS_WEBHOOK_SECRET=

# ---- Database persistence (optional) ----

# PostgreSQL connection string. Leave blank to run without persistence.
# Example: postgres://localhost:5432/meme_trading_system_v1?sslmode=disable
DATABASE_URL=

# ---- Live decision thresholds (all optional — defaults shown) ----

TRADE_SIZE_SOL=1.0
LIQUIDITY_MULTIPLIER=20.0
MIN_EXEC_QUALITY_BUY=0.5
MIN_EXEC_QUALITY_READY=0.3
MIN_EXEC_QUALITY_AVOID=0.1
MAX_ADVERSARIAL_BUY=0.60
MAX_ADVERSARIAL_READY=0.75
MAX_ESTIMATED_IMPACT_PCT=15.0
MAX_SIGNAL_AGE_MINUTES_BUYREADY=5
MAX_SIGNAL_AGE_MINUTES_WATCH=15
MIN_TOKEN_AGE_SECONDS_FOR_BUY=90
MIN_EFFECTIVE_BUYERS_1M_FOR_CONFIDENT_BUY=3
MIN_TOTAL_EVENTS_FOR_CONFIDENCE=3

# ---- Dashboard (cmd/dashboard) ----

# Set to 1 to enable live mode (polls ingestor).
# Set to 0 for offline CSV-backed mode.
LIVE_MODE=1

# URL of the running ingestor.
INGESTOR_URL=http://localhost:8080

# Dashboard poll interval in seconds. Default: 10.
REFRESH_INTERVAL_SEC=10

# ---- Admin (disabled by default — localhost only) ----

ENABLE_LOCAL_ADMIN=0

# ---- Helius push webhook (OPTIONAL — advanced only) ----
#
# The primary ingress path is the built-in poll poller above.
# You do NOT need a webhook for broad market discovery.
#
# Only configure these if you want Helius to push events directly
# (requires cloudflared tunnel or deployed server).
#
# Comma-separated Solana addresses for Helius to watch.
# Helius requires at least one address — an empty list returns HTTP 400.
HELIUS_ACCOUNT_ADDRESSES=

# Webhook ID returned by Helius on first registration.
# Leave blank on first run; set to update an existing webhook.
HELIUS_WEBHOOK_ID=

# ---- Cloudflare tunnel (optional — local live testing only) ----

# PUBLIC_BASE_URL is NOT stored in .env — it changes every cloudflared session.
# Export it in your shell before running make set-helius-webhook:
#   export PUBLIC_BASE_URL=https://<assigned>.trycloudflare.com
